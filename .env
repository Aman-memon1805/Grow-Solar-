# ─── Server ───────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string or local URI
MONGO_URI=mongodb://localhost:27017/solarvolt

# ─── JWT Secret ───────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=solarvolt_super_secret_key_change_in_production

# ─── Admin Seed ───────────────────────────────────────────────
# Default admin credentials created on first run
ADMIN_EMAIL=admin@solarvolt.in
ADMIN_PASSWORD=Admin@1234
